# ══════════════════════════════════════════════════════════════
# Agent Design Patterns — Environment Configuration
# Copy to .env and fill in your keys:  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────
# Two vars control the model:
#   MODEL_PROVIDER  — provider name registered with langchain-dev-utils
#   MODEL_NAME      — model identifier for that provider
#
# Default: ernie provider + ernie-5.1 via AI Studio.
MODEL_PROVIDER=ernie                      # "ernie" | "openai" | "anthropic"
MODEL_NAME=ernie-5.1                      # model name for the selected provider

# OpenAI-compatible endpoint credentials (used by ernie + openai providers)
# Get your AI Studio key at: https://aistudio.baidu.com/account/accessToken
OPENAI_API_KEY=                           # your API key
OPENAI_BASE_URL=https://aistudio.baidu.com/llm/lmapi/v3

# ── Alternative providers (uncomment one block) ──

# OpenAI (direct)
# Get your key at: https://platform.openai.com/api-keys
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                        # leave empty for api.openai.com

# Anthropic
# Get your key at: https://console.anthropic.com/settings/keys
# MODEL_PROVIDER=anthropic
# MODEL_NAME=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith (optional: tracing & observability) ──
# Get your key at: https://smith.langchain.com/settings/apikeys
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agent-design-patterns
LANGSMITH_TRACING=true                    # set false to disable
